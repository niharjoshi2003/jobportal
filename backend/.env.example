# ============ DATABASE ============
# MongoDB connection string. Get this from MongoDB Atlas (https://cloud.mongodb.com)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/jobportal?retryWrites=true&w=majority"

# ============ JWT & SECURITY ============
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SECRET_KEY="REPLACE_ME_WITH_64_HEX_CHARS_MIN"
JWT_EXPIRY="1d"

# ============ ADMIN SIGNUP ============
# Secret code required to sign up with role="admin". Treat like a password.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SIGNUP_CODE="REPLACE_ME_WITH_LONG_RANDOM_STRING"

# ============ SERVER ============
PORT=8000
NODE_ENV="development"

# ============ CORS ============
# Comma-separated list of allowed frontend origins (Vite dev server default is 5173)
FRONTEND_URL="http://localhost:5173"

# ============ FILE UPLOAD (Cloudinary) ============
# Get these from https://console.cloudinary.com (Account Details)
CLOUDINARY_CLOUD_NAME="your_cloudinary_name"
CLOUDINARY_API_KEY="your_cloudinary_key"
CLOUDINARY_API_SECRET="your_cloudinary_secret"

# ============ EMAIL (optional, for future verification / interview invites) ============
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Job-O-Hire <no-reply@jobohire.com>"

# ============ RATE LIMITING ============
# Auth endpoints: max attempts per window
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
